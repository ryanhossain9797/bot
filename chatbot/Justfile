build_push tag="latest":
    #!/usr/bin/env bash
    set -euxo pipefail
    docker build -t zireael9797/bot:{{tag}} -f Dockerfile ..
    docker push zireael9797/bot:{{tag}}

build_local tag="latest":
    #!/usr/bin/env bash
    set -euxo pipefail
    docker build -t zireael9797/bot:{{tag}} -f Dockerfile ..

build_base tag="latest":
    #!/usr/bin/env bash
    set -euxo pipefail
    docker build -t zireael9797/bot-base:{{tag}} -f Dockerfile.base .

run_local tag="latest":
    #!/usr/bin/env bash
    set -euxo pipefail
    docker stop bot 2>/dev/null || true
    docker rm bot 2>/dev/null || true
    docker run -d \
        --name bot \
        --network host \
        --device=/dev/kfd \
        --device=/dev/dri \
        --group-add video \
        --group-add render \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -e MODEL_PACK_DIR=/app/models/qwen-qwen3-6-35b-a3b \
        -e UTILITY_MODEL_PACK_DIR=/app/models/qwen3-4b \
        --restart unless-stopped \
        zireael9797/bot:{{tag}}

deploy_local tag="latest":
    #!/usr/bin/env bash
    set -euxo pipefail
    just build_local {{tag}}
    just run_local {{tag}}
